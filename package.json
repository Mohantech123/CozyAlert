{
  "name": "cozy-popup",
  "version": "0.1.6",
  "description": "A cross-framework customizable alert library for React, Angular, Vue and Vanilla JavaScript.",
  "author": "Mohan Kumar",
  "license": "MIT",
  "keywords": [
    "cozy-popup",
    "cozypopup",
    "cozy-alert",
    "cozyalert",
    "cozy-modal",
    "cozymodal",
    "cozy-dialog",
    "cozydialog",
    "cozy-toast",
    "cozytoast",
    "toast",
    "offcanvas",
    "drawer",
    "notification",
    "sweetalert",
    "sweetalert2",
    "sweetalert-alternative",
    "framework-agnostic",
    "react",
    "react-alert",
    "angular",
    "vue",
    "vue-alert",
    "nextjs",
    "svelte",
    "solidjs",
    "vanilla-js",
    "javascript",
    "typescript",
    "ui",
    "component",
    "prompt",
    "confirm",
    "form",
    "customizable",
    "metadata driven ui",
    "Dynamic Form",
    "cozy-popup",
    "cozypopup",
    "alert",
    "modal",
    "dialog",
    "popup"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "npm run build:vanilla",
    "build:vanilla": "tsup src/index.ts --format esm,cjs,iife --globalName CozyAlert --dts",
    "build:angular": "node scripts/sync-core.cjs && cd angular-workspace && npm run build CozyPopup",
    "build:all": "npm run build:vanilla && npm run build:angular",
    "dev": "tsup src/index.ts --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mohantech123/CozyAlert.git"
  },
  "homepage": "https://mohantech123.github.io/CozyAlert/",
  "funding": "https://github.com/sponsors/Mohantech123",
  "bugs": {
    "url": "https://github.com/Mohantech123/CozyAlert/issues"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.5.4"
  }
}
